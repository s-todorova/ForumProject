@page
@model LoginModel

@{
    ViewData["Title"] = "Вход";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-6 col-lg-4">
        <div class="card shadow-sm border-0 rounded-4 p-4 p-md-5 bg-white">
            <h2 class="text-center fw-bold mb-2" style="color: #4f46e5;">@ViewData["Title"]</h2>
            <p class="text-center text-muted mb-4">Влезте във вашия профил.</p>
            
            <section>
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control rounded-3" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email" class="form-label">Имейл адрес</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control rounded-3" autocomplete="current-password" aria-required="true" placeholder="password" />
                        <label asp-for="Input.Password" class="form-label">Парола</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input" asp-for="Input.RememberMe" id="rememberMeCheck" />
                            <label class="form-check-label text-muted" for="rememberMeCheck">
                                Запомни ме
                            </label>
                        </div>
                        <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none small" style="color: #06b6d4;">Забравена парола?</a>
                    </div>
                    
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg text-white rounded-pill shadow-sm" style="background-color: #4f46e5;">Влез сега</button>
                    
                    <div class="text-center mt-4">
                        <p class="mb-0 text-muted">Нямате профил? 
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none fw-bold" style="color: #4f46e5;">Регистрирайте се</a>
                        </p>
                    </div>
                </form>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}