@page
@model RegisterModel
@{
    ViewData["Title"] = "Регистрация";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-6 col-lg-4">
        <div class="card shadow-sm border-0 rounded-4 p-4 p-md-5 bg-white">
            <h2 class="text-center fw-bold mb-2" style="color: #4f46e5;">@ViewData["Title"]</h2>
            <p class="text-center text-muted mb-4">Създаване на нов профил в Nexus.</p>
            
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control rounded-3" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Имейл адрес</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control rounded-3" autocomplete="new-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password">Парола</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                
                <div class="form-floating mb-4">
                    <input asp-for="Input.ConfirmPassword" class="form-control rounded-3" autocomplete="new-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.ConfirmPassword">Потвърдете паролата</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>
                
                <button id="registerSubmit" type="submit" class="w-100 btn btn-lg text-white rounded-pill shadow-sm" style="background-color: #4f46e5;">Регистрирай се</button>
            </form>
            
            <div class="text-center mt-4">
                <p class="mb-0 text-muted">Вече имате профил? 
                    <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none" style="color: #06b6d4; font-weight: 500;">Влезте тук</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}