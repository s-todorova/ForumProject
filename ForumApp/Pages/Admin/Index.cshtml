@page
@model ForumApp.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Административен панел";
}

<div class="container mt-4 mb-5">
    <h2 class="fw-bold mb-4" style="color: #1f2937;">Табло за управление</h2>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden bg-white">
        <div class="row g-0" style="min-height: 75vh;">
            
            <div class="col-md-3 bg-light border-end">
                <div class="p-4">
                    <div class="nav flex-column nav-pills" id="v-pills-tab" role="tablist" aria-orientation="vertical">
                        <button class="nav-link active text-start fw-bold mb-2 rounded-3" id="v-pills-stats-tab" data-bs-toggle="pill" data-bs-target="#v-pills-stats" type="button" role="tab" aria-controls="v-pills-stats" aria-selected="true">
                            📊 Статистика
                        </button>
                        <button class="nav-link text-start fw-bold rounded-3" id="v-pills-users-tab" data-bs-toggle="pill" data-bs-target="#v-pills-users" type="button" role="tab" aria-controls="v-pills-users" aria-selected="false">
                            👥 Управление на потребители
                        </button>
                    </div>
                </div>
            </div>

            <div class="col-md-9">
                <div class="p-4 p-md-5">
                    <div class="tab-content" id="v-pills-tabContent">
                        
                        <div class="tab-pane fade show active" id="v-pills-stats" role="tabpanel" aria-labelledby="v-pills-stats-tab">
                            <h4 class="fw-bold mb-4" style="color: #4f46e5;">Общ преглед на системата</h4>
                            
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="border rounded-3 p-3 text-center bg-light">
                                        <h3 class="fw-bold text-dark mb-0">@Model.TotalUsers</h3>
                                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">Регистрирани</small>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="border rounded-3 p-3 text-center bg-light border-success">
                                        <h3 class="fw-bold text-success mb-0">@Model.ActiveUsers</h3>
                                        <small class="text-success text-uppercase fw-bold" style="font-size: 0.75rem;">Активни</small>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="border rounded-3 p-3 text-center bg-light border-primary">
                                        <h3 class="fw-bold text-primary mb-0">@Model.ModeratorsCount</h3>
                                        <small class="text-primary text-uppercase fw-bold" style="font-size: 0.75rem;">Модератори</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="v-pills-users" role="tabpanel" aria-labelledby="v-pills-users-tab">
                            <h4 class="fw-bold mb-4" style="color: #4f46e5;">Управление на акаунти</h4>
                            
                            <div class="table-responsive rounded-4 border">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4">Потребител (Имейл)</th>
                                            <th>Роля</th>
                                            <th>Статус</th>
                                            <th class="text-end pe-4">Действия</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var user in Model.UsersList)
                                        {
                                            <tr>
                                                <td class="ps-4 fw-bold">@user.Email</td>
                                                <td>
                                                    @if (user.Roles.Contains("Admin")) { <span class="badge bg-danger">Админ</span> }
                                                    else if (user.Roles.Contains("Moderator")) { <span class="badge bg-primary">Модератор</span> }
                                                    else { <span class="badge bg-secondary">Потребител</span> }
                                                </td>
                                                <td>
                                                    @if (user.IsActive) { <span class="badge bg-success bg-opacity-10 text-success border border-success">Активен</span> }
                                                    else { <span class="badge bg-danger bg-opacity-10 text-danger border border-danger">Блокиран</span> }
                                                </td>
                                                <td class="text-end pe-4">
                                                    @if (user.Email != User.Identity?.Name)
                                                    {
                                                        <form method="post" class="d-inline">
                                                            <button type="submit" asp-page-handler="ToggleModerator" asp-route-id="@user.Id" class="btn btn-sm @(user.Roles.Contains("Moderator") ? "btn-outline-secondary" : "btn-outline-primary") rounded-pill px-3 me-1">
                                                                @(user.Roles.Contains("Moderator") ? "Премахни Модератор" : "Направи Модератор")
                                                            </button>
                                                            
                                                            <button type="submit" asp-page-handler="ToggleStatus" asp-route-id="@user.Id" class="btn btn-sm @(user.IsActive ? "btn-outline-danger" : "btn-outline-success") rounded-pill px-3">
                                                                @(user.IsActive ? "Деактивирай" : "Активирай")
                                                            </button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted small">Вашият профил</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            
        </div>
    </div>
</div>