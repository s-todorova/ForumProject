@page
@model IndexModel
@{
    ViewData["Title"] = "Начало";
}

<div class="container my-4">
    <div class="rounded-4 shadow-lg text-white overflow-hidden" style="background: linear-gradient(135deg, #4f46e5 0%, #06b6d4 100%);">
        <div class="row align-items-center py-5 px-4 px-lg-5">
            @* <div class="col-lg-8 pe-lg-5">
                <h1 class="display-4 fw-bold mb-4">Пространство за истински разговори</h1>
                <p class="fs-5 mb-4 lh-base" style="color: rgba(255,255,255,0.85);">
                    Присъедини се към общността. Споделяй идеи, обсъждай важните теми и намирай отговори. Нашата интелигентна модерация се грижи средата да остане чиста и освободена от токсичност.
                </p>
                <div class="d-flex flex-wrap gap-3 mt-4">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-page="/Posts/Create" class="btn btn-light btn-lg px-4 fw-bold shadow-sm rounded-pill" style="color: #4f46e5;">Създай нова тема</a>
                        <a href="#discussions" class="btn btn-outline-light btn-lg px-4 shadow-sm rounded-pill">Разгледай</a>
                    }
                    else
                    {
                        <a class="btn btn-light btn-lg px-4 fw-bold shadow-sm rounded-pill" style="color: #4f46e5;" asp-area="Identity" asp-page="/Account/Register">Присъедини се сега</a>
                        <a class="btn btn-outline-light btn-lg px-4 shadow-sm rounded-pill" asp-area="Identity" asp-page="/Account/Login">Вход</a>
                    }
                </div>
            </div> *@
            
            <div class="col-lg-8 pe-lg-5">
                <h1 class="display-5 fw-bold mb-4">Автоматична модерация на съдържание</h1>
                <p class="fs-5 mb-4 lh-base" style="color: rgba(255,255,255,0.85);">
                    Демонстрационно уеб приложение, интегриращо модел за машинно обучение (ML) за класификация на текст. Системата автоматично анализира потребителските коментари и филтрира нецензурно или грубо съдържание в реално време.
                </p>
                <div class="d-flex flex-wrap gap-3 mt-4">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-page="/Posts/Create" class="btn btn-light btn-lg px-4 fw-bold shadow-sm rounded-pill" style="color: #4f46e5;">Създай тема</a>
                    }
                    else
                    {
                        <a class="btn btn-light btn-lg px-4 fw-bold shadow-sm rounded-pill" style="color: #4f46e5;" asp-area="Identity" asp-page="/Account/Register">Създай профил</a>
                        <a class="btn btn-outline-light btn-lg px-4 shadow-sm rounded-pill" asp-area="Identity" asp-page="/Account/Login">Вход в системата</a>
                    }
                </div>
            </div>

            <div class="col-lg-4 text-center d-none d-lg-block">
                 <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" style="opacity: 0.9;" width="200" height="200">
                    <path d="M12 3c5.5 0 10 3.58 10 8s-4.5 8-10 8c-1.24 0-2.43-.18-3.53-.5C5.55 21 2 21 2 21c2.33-2.33 2.7-3.9 2.75-4.25C3.06 15.07 2 13.13 2 11c0-4.42 4.5-8 10-8zm0 2c-4.42 0-8 2.69-8 6 0 1.7.94 3.2 2.39 4.22.38.27.61.7.58 1.15-.06.74-.32 1.63-.82 2.5 1.5-.27 2.8-.88 3.73-1.45.31-.19.68-.24 1.02-.14 1.01.32 2.08.5 3.2.5 4.42 0 8-2.69 8-6s-3.58-6-8-6z"/>
                 </svg>
            </div>
        </div>
    </div>
</div>

<div class="container mt-5 mb-5" id="discussions">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0 text-dark">Активни дискусии</h3>
        <span class="badge rounded-pill fs-6 px-3 py-2 shadow-sm" style="background-color: #4f46e5;">@Model.Posts.Count теми</span>
    </div>
    
    @if (Model.Posts.Count == 0)
    {
        <div class="card shadow-sm border-0 bg-light rounded-4">
            <div class="card-body text-center py-5">
                <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" fill="currentColor" class="bi bi-chat-square-text text-secondary mb-3 opacity-50" viewBox="0 0 16 16">
                  <path d="M14 1a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1h-2.5a2 2 0 0 0-1.6.8L8 14.333 6.1 11.8a2 2 0 0 0-1.6-.8H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h12zM2 0a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2.5a1 1 0 0 1 .8.4l1.9 2.533a1 1 0 0 0 1.6 0l1.9-2.533a1 1 0 0 1 .8-.4H14a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2z"/>
                  <path d="M3 3.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zM3 6a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9A.5.5 0 0 1 3 6zm0 2.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5z"/>
                </svg>
                <h4 class="text-secondary fw-normal">Все още няма създадени теми.</h4>
                <p class="text-muted mb-0">Бъди първият, който ще започне разговор!</p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var post in Model.Posts)
            {
                <div class="col-12">
                    <div class="card shadow-sm border-0 rounded-4 h-100 position-relative" style="background-color: #f9fafb; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 28px; height: 28px;">
                                    <span class="fw-bold" style="color: #4f46e5; font-size: 0.75rem;">
                                        @(post.Author?.UserName?.Substring(0, 1).ToUpper() ?? "?")
                                    </span>
                                </div>
                                <span class="text-muted small">
                                    <span class="fw-bold text-dark">@(post.Author?.UserName?.Split('@')[0] ?? "Неизвестен")</span>
                                    <span class="mx-1">&bull;</span>
                                    @post.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                </span>
                            </div>
                            
                            <h4 class="fw-bold mb-2">
                                <a asp-page="/Posts/Details" asp-route-id="@post.Id" class="text-decoration-none text-dark stretched-link">@post.Title</a>
                            </h4>
                            
                            <p class="text-muted mb-3">
                                @(post.Content.Length > 150 ? post.Content.Substring(0, 150) + "..." : post.Content)
                            </p>
                            
                            <div class="d-flex align-items-center text-muted small mt-3 pt-3 border-top">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chat-dots me-2" viewBox="0 0 16 16">
                                    <path d="M5 8a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm4 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm3 1a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/>
                                    <path d="M2.165 15.803l.02-.004c1.83-.363 2.948-.842 3.468-1.105A9.06 9.06 0 0 0 8 15c4.418 0 8-3.134 8-7s-3.582-7-8-7-8 3.134-8 7c0 1.76.743 3.37 1.97 4.6a10.437 10.437 0 0 1-.524 2.318l-.003.011a10.722 10.722 0 0 1-.244.637c-.079.186.074.394.273.362a21.673 21.673 0 0 0 .693-.125zm.8-3.108a1 1 0 0 0-.287-.801C1.618 10.83 1 9.468 1 8c0-3.192 3.004-6 7-6s7 2.808 7 6-3.004 6-7 6a8.06 8.06 0 0 1-2.088-.272 1 1 0 0 0-.711.074c-.387.196-1.24.57-2.634.893a10.97 10.97 0 0 0 .398-2z"/>
                                </svg>
                                <span class="fw-bold">@post.Comments.Count коментара</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>